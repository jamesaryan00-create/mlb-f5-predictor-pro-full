# Optional but recommended: The Odds API key for live moneyline/spread/total odds.
ODDS_API_KEY=
ODDS_MARKETS=h2h,spreads,totals
ODDS_REGIONS=us

# Optional custom JSON endpoints if you have paid/approved feeds.
# The app will display these as unavailable until configured.
INJURY_API_URL=
UMPIRE_API_URL=

# Optional: train seasons for machine learning script.
# Example: TRAIN_SEASONS=2024,2025 npm run train:ml
TRAIN_SEASONS=2024,2025
